# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Built binaries
/tclaude

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Visual smoke-harness output (dashsnap, JOH-386): timestamped PNGs +
# the index.html contact sheet. Regenerated on demand, never committed.
/dashsnap-out/

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/
.idea/

TODO.md
DOING.md
DONE.md
# ...but keep the checked-in task-runner demo definition
!examples/task-runner-demo/TODO.md

# macOS Finder metadata
.DS_Store

# Excalidraw MCP local log
excalidraw.log
.claude/worktrees/

# Sandbox artifacts — /dev/null device nodes the isolation-worktree
# sub-agent sandbox drops in the repo root to mask the ambient host
# config (~/.bashrc, ~/.gitconfig, …) from sandboxed sub-agents.
# Harmless (not real files); ignored so they cannot be staged by
# accident. NOTE: .mcp.json / .vscode / .gitmodules / .claude/agents /
# .claude/commands / .claude/hooks / .claude/launch.json /
# .claude/routines / .claude/workflows could be legitimate project files
# someday — drop the matching line here if tclaude ever gains a real one.
/.bash_profile
/.bashrc
/.gitconfig
/.gitmodules
/.idea
/.mcp.json
/.profile
/.ripgreprc
/.vscode
/.zprofile
/.zshrc
/.claude/agents
/.claude/commands
/.claude/hooks
/.claude/launch.json
/.claude/routines
/.claude/workflows
