# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Built binaries
/tclaude

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Visual smoke-harness output (dashsnap, JOH-386): timestamped PNGs +
# the index.html contact sheet. Regenerated on demand, never committed.
/dashsnap-out/

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/
.idea/

TODO.md
DOING.md
DONE.md

# macOS Finder metadata
.DS_Store

# Excalidraw MCP local log
excalidraw.log
.claude/worktrees/

# Sandbox artifacts — /dev/null device nodes Claude Code's Bash sandbox
# bind-mounts over paths it denies, in any sandboxed session (not just
# isolation worktrees): ambient host config (~/.bashrc, ~/.gitconfig, …)
# and its own protected settings/runtime paths under .claude/. Harmless
# (not real files), but git chokes on unignored ones: they show as
# untracked in `git status`, and `git add -A` / `git add .` fail hard
# ("can only add regular files"). Ignored so bulk staging works.
# NOTE: several of these could be legitimate project files someday —
# .mcp.json / .vscode / .gitmodules / the .claude/ entries
# (.claude/settings.json in particular is a documented pattern for
# committed project-scoped Claude Code settings) — drop the matching
# line here if tclaude ever gains a real one.
/.bash_profile
/.bashrc
/.gitconfig
/.gitmodules
/.idea
/.mcp.json
/.profile
/.ripgreprc
/.vscode
/.zprofile
/.zshrc
/.claude/agents
/.claude/commands
/.claude/hooks
/.claude/launch.json
/.claude/loop.md
/.claude/output-styles
/.claude/routines
/.claude/scheduled_tasks.json
/.claude/settings.json
/.claude/settings.local.json
/.claude/workflows

# Claude Code runtime write-journal (a real directory, created in-repo
# by sandboxed sessions; empty today but never a project file).
/.claude/.cc-writes/
